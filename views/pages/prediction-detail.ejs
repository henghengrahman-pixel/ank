<%- include('../partials/head') %>

<div class="site-shell" style="--bg-main:url('<%= site.backgroundMain %>');">
  <%- include('../partials/header') %>

  <main class="container main-content">

    <!-- HERO SLIDER + LOGIN -->
    <section class="hero glass home-hero-box">
      <div class="slider-wrap">
        <div class="slider" data-slider>
          <% sliders.forEach(function(slide, index){ %>
            <div class="slide <%= index === 0 ? 'active' : '' %>">
              <img src="<%= slide.imageUrl %>" alt="<%= slide.title %>" />
            </div>
          <% }) %>
        </div>
      </div>

      <div class="home-cta-row">
        <a href="<%= site.loginLink %>" class="big-btn">LOGIN</a>
        <a href="<%= site.registerLink %>" class="big-btn secondary">DAFTAR</a>
        <a href="/prediksi" class="big-btn accent">PREDIKSI</a>
      </div>
    </section>

    <!-- DETAIL PREDIKSI -->
    <section class="prediction-detail-clean glass">
      <a href="/prediksi" class="back-pill">← Beranda Prediksi</a>

      <h1 class="prediction-title">
        PREDIKSI <%= market.name.toUpperCase() %> TOGEL HARI INI OMTOGEL
        <%= current ? current.date : '-' %>
      </h1>

      <img src="<%= market.logoUrl %>" class="detail-logo-center" />

      <% if (current) { %>

      <div class="prediction-center">
        <div class="row-line">
          <span>ANGKA MAIN :</span>
          <strong>( <%= current.angkaMain %> )</strong>
        </div>

        <div class="row-line">
          <span>TOP 4D (BB) :</span>
          <strong><%= current.top4d %></strong>
        </div>

        <div class="row-line">
          <span>TOP 3D (BB) :</span>
          <strong><%= current.top3d %></strong>
        </div>

        <div class="row-line">
          <span>TOP 2D (BB) :</span>
          <strong><%= current.top2d %></strong>
        </div>

        <div class="row-line">
          <span>COLOK BEBAS :</span>
          <strong><%= current.colokBebas %></strong>
        </div>

        <div class="row-line">
          <span>COLOK 2D :</span>
          <strong><%= current.colok2d %></strong>
        </div>

        <div class="row-line">
          <span>SHIO JITU :</span>
          <strong><%= current.shio %></strong>
        </div>
      </div>

      <% } %>
    </section>

    <!-- HISTORY -->
    <section class="history-strip glass">
      <h2 class="history-title">
        PREDIKSI <%= market.name.toUpperCase() %> SEBELUMNYA
      </h2>

      <div class="history-cards">
        <% if (history && history.length) { %>
          <% history.forEach(function(item){ %>
            <div class="history-card glass">
              <img src="<%= market.logoUrl %>" />
              <div class="history-date"><%= item.date %></div>
              <strong class="history-number"><%= item.angkaMain %></strong>
              <small class="history-shio"><%= item.shio %></small>
            </div>
          <% }) %>
        <% } else { %>
          <div class="empty-state">Belum ada history prediksi.</div>
        <% } %>
      </div>
    </section>

  </main>

  <%- include('../partials/footer') %>
</div>
